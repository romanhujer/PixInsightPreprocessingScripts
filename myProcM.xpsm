   <instance class="PixelMath" version="256" id="Ha_to_RGB_Advanced_V1_instance">
      <parameter id="expression">/*  Add Ha to RGB Image with Ha Lightness - Advanced Mode-V1 
                    by Bill Blanshan                */

Mode=         0   ;//0: Nebula mode, 1: Galaxy mode
StarMode=     0   ;// 0: RGB Stars, 1: Ha Stars, 2: Blend
Brightness=  1.00 ;// Lightness brightness control,&lt;1: darker
HaStrength=  1.00 ;/* Increase Ha region brightness,&gt;1: brighter


Important for this to work!!
1) Your Ha image must be named &quot;Ha&quot; 
2) Your Starless Ha image must be named &quot;Starless_Ha&quot;
3) Your Starless RGB image must be named &quot;Starless_RGB&quot;       

Drag the bottom left arrow over to your RGB image

Hope you enjoy!!!      */













// Normalize Ha to Red or RGB to HA
k1= adev(Starless_RGB[0])/adev(Starless_Ha); 
k2= adev(Starless_Ha)/adev(Starless_RGB[0]); 
N1= (k1*(Starless_Ha-med(Starless_Ha))+med(Starless_RGB[0]));//Ha
N2= (k2*(Starless_RGB[0]-med(Starless_RGB[0]))+med(Starless_Ha));//R
N3= rescale(~(~Starless_Ha/~N2),0,1); //Ha-(Red normalized to Ha)
N4= rescale(~(~N1/~Starless_RGB[0]),0,1);//Ha-(Ha normalized to Red)
N5= iif(k1&gt;k2,N3,N4); //Final Ha only
N6= ~((~$T[0]/~Starless_RGB[0])*(~Starless_RGB[0]*~N5));//New Red

////New Lightness
E1= ~(~CIEL($T)/~CIEL(Starless_RGB)); //&lt;--Unscreen RGB Stars &quot;L&quot;
E2= ~(~CIEL(Ha)/~CIEL(Starless_Ha)); //&lt;--Unscreen Ha Stars &quot;L&quot;
E3= max(mdev($T[0]),mdev($T[1]),mdev($T[2]),
    mdev(Starless_Ha))/4;
E4= mtf((1/HaStrength*.5),N5-E3);//Ha diff with Stretch
E5= iif(Mode==0,Starless_Ha,
    ~(~CIEL(Starless_RGB)*~E4));// New Lightness
E6= (E5*(Brightness*E5))+(E5*~E5); //New Lightness adjusted
E7= iswitch(StarMode==0,~(~E1*~E6),StarMode==1,~(~E2*~E6),
    mean(~(~E1*~E6),~(~E2*~E6))); //New lightness with Stars

// RGB to L.a.b 
R1= iif(N6&gt;0.04045, ((N6+0.055)/1.055)^ 2.4,N6/ 12.92);
G1= iif($T[1]&gt;0.04045, (($T[1]+0.055)/1.055)^ 2.4,$T[1]/ 12.92);
B1= iif($T[2]&gt;0.04045, (($T[2]+0.055)/1.055)^ 2.4,$T[2]/ 12.92);
X= ((R1*0.4360747) + (G1*0.3850649) + (B1*0.1430804));
Y= ((R1*0.2225045) + (G1*0.7168786) + (B1*0.0606169));
Z= ((R1*0.0139322) + (G1*0.0971045) + (B1*0.7141733));
X1= iif(X&gt;0.008856, X^(1/3),(7.787*X)+(16/116) );
Y1= iif(Y&gt;0.008856, Y^(1/3),(7.787*Y)+(16/116) );
Z1= iif(Z&gt;0.008856, Z^(1/3),(7.787*Z)+(16/116) );
L= 116*Y1-16;  
a= (500*(X1-Y1));  
b= (200*(Y1-Z1));   

// L.a.b to RGB
Y2= (E7+.16)/1.16;
X2= (a/500)+Y2;
Z2= Y2-(b/200);
X3= iif(X2&gt;0.008856, X2^3,(X2-16/116)/7.787);
Y3= iif(Y2&gt;0.008856, Y2^3,(Y2-16/116)/7.787);
Z3= iif(Z2&gt;0.008856, Z2^3,(Z2-16/116)/7.787);
R2= ((X3* 3.1338561) + (Y3*-1.6168667) + (Z3*-0.4906146));
G2= ((X3*-0.9787684) + (Y3* 1.9161415) + (Z3* 0.0334540));
B2= ((X3* 0.0719453) + (Y3*-0.2289914) + (Z3* 1.4052427));
R3= iif(R2&gt;0.0031308, 1.055*(R2^(1/2.4))-0.055,12.92*R2);
G3= iif(G2&gt;0.0031308, 1.055*(G2^(1/2.4))-0.055,12.92*G2);
B3= iif(B2&gt;0.0031308, 1.055*(B2^(1/2.4))-0.055,12.92*B2);

iif($T==$T[0],R3,iif($T==$T[1],G3,B3)); //Final




/*Notes: Brightness adjustment is a linear stretch of the starless
         data where as HaStrength adjustment is non-linear curve
         adjustment stretch  */</parameter>
      <parameter id="expression1"></parameter>
      <parameter id="expression2"></parameter>
      <parameter id="expression3"></parameter>
      <parameter id="useSingleExpression" value="true"/>
      <parameter id="symbols">StarMode,HaStrength,Brightness,Mode,
k1,k2,N1,N2,N3,N4,N5,N6,
I1,I2,I3,S1,S2,S3,
E1,E2,E3,E4,E5,E6,E7,E8,
R1,G1,B1,R2,G2,B2,R3,G3,B3,
X,Y,Z,X1,Y1,Z1,X2,Y2,Z2,X3,Y3,Z3,
L,a,b,</parameter>
