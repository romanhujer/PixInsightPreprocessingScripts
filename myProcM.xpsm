   <instance class="PixelMath" version="256" id="Bills_Stretch_Llinked__V4_instance">
      <parameter id="expression">/*      Linked Stretch Test with Curve Adjustment         
                    by Bill Blanshan                     */


Stretch=  0.20 ; //&lt;-- Target background value
Curve=    1.00 ; //&lt;-- 1= MTF style, &gt;1= Reduce Highlights



//Drag the bottom left arrow over into the image you want stretched 


















m = (med($T[0])+med($T[1])+med($T[2]))/3;
d = (mdev($T[0])+mdev($T[1])+mdev($T[2]))/3;
E1= min(max(0,m+-2.8*1.4826*d),1);
E2= max(0,($T-E1)/~E1);
E3= m-E1;
E4= min(1,(1/Curve));
E5= ((Stretch-1)*E3) / ((2*Stretch-1) * E3^E4-Stretch); //MTF value
E6= ( (E5-1)*E2) / ( (2*E5-1) * E2^E4-E5);

E6</parameter>
      <parameter id="expression1"></parameter>
      <parameter id="expression2"></parameter>
      <parameter id="expression3"></parameter>
      <parameter id="useSingleExpression" value="true"/>
      <parameter id="symbols">Stretch,Curve,m,d,
E1,E2,E3,E4,E5,E6,E7,</parameter>
