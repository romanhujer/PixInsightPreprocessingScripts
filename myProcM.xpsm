   <instance class="PixelMath" version="256" id="RGBstars_to_NB_V14_instance">
      <parameter id="expression">/*      RGB Stars-to-Narrowband Transfer using PixelMath - V14 
                     by Bill Blanshan                          */
                    
//Drag the bottom left arrow over to your RGB image with stars

Img1= Starless_RGB   ;// &lt;-- RGB Starless Image name
Img2= Starless_NB    ;// &lt;-- Narrowband Starless Image name
















//Equations.....
S= 0.05;  //Forward and reverse stretch control
I1= min(.999,$T);//&lt;--Protects image when dividing
I2= min(.999,Img1);//&lt;--Protects image when dividing
I3= min(.999,Img2);//&lt;--Protects image when dividing
E1= mtf(~S,I1); //&lt;--Reverse Stretch-RGB image
E2= mtf(~S,I2); //&lt;--Reverse Stretch-RGB Starless image
E3= mtf(~S,I3);  //&lt;--Reverse Stretch-NB Starless image
E4= rescale(~(~E1/~E2),0,1); //&lt;--Reverse Stretch-Unscreen Stars
E5= rescale(~(~I1/~I2),0,1);  //&lt;--Unscreen Stars
E6= min(.999,~(~E5*~I3)); //&lt;--Use for Lightness

E9= E5[0]*0.2126+E5[1]*0.7152+E5[2]*0.0722; //&lt;-Star mask
E10= rescale(E9,0,.50); 

// Create New Lightness
R= iif(E6[0]&gt;0.04045, ((E6[0]+0.055)/1.055)^ 2.4,E6[0]/ 12.92);
G= iif(E6[1]&gt;0.04045, ((E6[1]+0.055)/1.055)^ 2.4,E6[1]/ 12.92);
B= iif(E6[2]&gt;0.04045, ((E6[2]+0.055)/1.055)^ 2.4,E6[2]/ 12.92);
Y_= ((R*0.2225045) + (G*0.7168786) + (B*0.0606169));
Y1_= iif(Y_&gt;0.008856, Y_^(1/3),(7.787*Y_)+(16/116) );
L_= 116*Y1_-16; 
 
E16= mtf(S,~(~E4*(~E3/~(~(~E3/~E2)*E10))) );//&lt;--

R1= iif(E16[0]&gt;0.04045, ((E16[0]+0.055)/1.055)^ 2.4,E16[0]/ 12.92);
G1= iif(E16[1]&gt;0.04045, ((E16[1]+0.055)/1.055)^ 2.4,E16[1]/ 12.92);
B1= iif(E16[2]&gt;0.04045, ((E16[2]+0.055)/1.055)^ 2.4,E16[2]/ 12.92);

X= ((R1*0.4360747) + (G1*0.3850649) + (B1*0.1430804));
Y= ((R1*0.2225045) + (G1*0.7168786) + (B1*0.0606169));
Z= ((R1*0.0139322) + (G1*0.0971045) + (B1*0.7141733));
X1= iif(X&gt;0.008856, X^(1/3),(7.787*X)+(16/116) );
Y1= iif(Y&gt;0.008856, Y^(1/3),(7.787*Y)+(16/116) );
Z1= iif(Z&gt;0.008856, Z^(1/3),(7.787*Z)+(16/116) );
L= 116*Y1-16;  
a= (500*(X1-Y1));  
b= (200*(Y1-Z1));   

Y2= (L_+16)/116;
X2= (a/500)+Y2;
Z2= Y2-(b/200);
X3= iif(X2&gt;0.008856, X2^3,(X2-16/116)/7.787);
Y3= iif(Y2&gt;0.008856, Y2^3,(Y2-16/116)/7.787);
Z3= iif(Z2&gt;0.008856, Z2^3,(Z2-16/116)/7.787);
R2= ((X3* 3.1338561) + (Y3*-1.6168667) + (Z3*-0.4906146));
G2= ((X3*-0.9787684) + (Y3* 1.9161415) + (Z3* 0.0334540));
B2= ((X3* 0.0719453) + (Y3*-0.2289914) + (Z3* 1.4052427));
R3= iif(R2&gt;0.0031308, 1.055*(R2^(1/2.4))-0.055,12.92*R2);
G3= iif(G2&gt;0.0031308, 1.055*(G2^(1/2.4))-0.055,12.92*G2);
B3= iif(B2&gt;0.0031308, 1.055*(B2^(1/2.4))-0.055,12.92*B2);

E18= iif($T==$T[0],R3,iif($T==$T[1],G3,B3)) ;

E18</parameter>
      <parameter id="expression1"></parameter>
      <parameter id="expression2"></parameter>
      <parameter id="expression3"></parameter>
      <parameter id="useSingleExpression" value="true"/>
      <parameter id="symbols">Img1,Img2,S,M,I1,I2,I3,
E0,E1,E2,E3,E4,E5,E6,E7,E8,E9,E10,E11,E12,E13,E14,E15,E16,E17,E18,E19,
E20,E21,E22,E23,E24,E25,E26,E27,E28,E29,E30,E31,E32,E33,E34,E35,
R,G,B,R1,G1,B1,R2,G2,B2,R3,G3,B3,L,a,b,Y_,Y1_,L_,
X,Y,Z,X1,Y1,Z1,X2,Y2,Z2,X3,Y3,Z3,</parameter>
      <parameter id="clearImageCacheAndExit" value="false"/>
      <parameter id="cacheGeneratedImages" value="false"/>
