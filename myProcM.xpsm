<xpsm version="1.0" xmlns="http://www.pixinsight.com/xpsm" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.pixinsight.com/xpsm http://pixinsight.com/xpsm/xpsm-1.0.xsd">
   <instance class="PixelMath" version="256" id="ModifiedSCNR_v5_instance">
      <time start="2025-03-22T03:55:29.905Z" span="6.4665135"/>
      <parameter id="expression">/*            Modified SCNR with Pixelmath -V5 
      Pixelmath by Bill Blanshan - Concept by James Lamb       

**Drag the bottom left arrow onto your image to process

**This process provides better Luminance protection than
  the standard SCNR process.  Special thanks to James Lamb
  for providing us the concept                         */

Amount= 0.95; //&lt;--Blend control      Hope you enjoy!!!












   



E1= $T[0]*.2126 + $T[1]*.7152 + $T[2]*0.0722; // Luminance
E2=  min(mean($T[0],$T[2]),$T[1]); // Average Neutral Mask
E3= $T[0]*.2126 + E2*.7152 + $T[2]*0.0722; //Luminance (Green Scaled)
E4= iif($T==$T[0],$T[0],iif($T==$T[1],E2,$T[2])); // New RGB
E5= E4*max(0.0000001,E1)/max(0.0000001,E3); //RGB with Lum
((E5*Amount)+($T*~Amount))</parameter>
      <parameter id="expression1"></parameter>
      <parameter id="expression2"></parameter>
      <parameter id="expression3"></parameter>
      <parameter id="useSingleExpression" value="true"/>
      <parameter id="symbols">Amount, E1,E2,E3,E4,E5,E6,E7,</parameter>
      <parameter id="clearImageCacheAndExit" value="false"/>
      <parameter id="cacheGeneratedImages" value="false"/>
      <parameter id="generateOutput" value="true"/>
      <parameter id="singleThreaded" value="false"/>
