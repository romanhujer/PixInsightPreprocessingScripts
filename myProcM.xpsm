   <instance class="PixelMath" version="256" id="HOONormalizationV4_instance">
      <parameter id="expression">/*       Normalize HOO data with Pixelmath - V4  
      by Bill Blanshan -- Concept by Luke Newbould     
                    
See &quot;Symbols&quot; tab for blending modifications

Drag the bottom left arrow over to your HOO image

Notes:
1) On symbols page, turn OFF OIII Scurve=0, On=1

2) Works best on a non-linear image; however, because this method
is a linear style stretch, stars in the image will most likely be
blown out.  It is best to remove the stars first.  The preferred
method to adding the stars back is using my RGB to Narrowband
pixel math so that star color is preserved.

Hope you enjoy!!!



*/
















$T[0]*BrightnessControl</parameter>
      <parameter id="expression1">k= adev($T[0])/adev($T[1]);
g1= ((k*OIIIBoost)*($T[1]-med($T[1]))+med($T[0]));
g2= 3*g1^2-2*g1^3; // &lt;--Simple S-curve
g3= iif(OIII_SCurve==0,g1,g2)*BrightnessControl;
g4= $T[0]*BrightnessControl;
g5= ((g3*~HaBlend)+(g4*HaBlend));
g5</parameter>
      <parameter id="expression2">k= adev($T[0])/adev($T[1]);
b1= ((k*OIIIBoost)*($T[1]-med($T[1]))+med($T[0]));
b2= 3*b1^2-2*b1^3; // &lt;--Simple S-curve
b3= iif(OIII_SCurve==0,b1,b2)*BrightnessControl;
b3</parameter>
      <parameter id="expression3"></parameter>
      <parameter id="useSingleExpression" value="false"/>
      <parameter id="symbols">OIIIBoost=          1.0 ;
HaBlend=            0.6 ;
BrightnessControl=  1.0 ;
OIII_SCurve=          0 ;














k,r1,g1,g2,g3,g4,g5,b1,b2,b3,</parameter>
