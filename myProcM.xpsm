   <instance class="PixelMath" version="256" id="Ha_to_RGB_Nebula_Simple_V1_instance">
      <time start="2022-12-10T22:04:03.612Z" span="4.6938932"/>
      <parameter id="expression">/*    Add Ha to RGB Image - Nebula Simple Mode - V1 
                   by Bill Blanshan              */

Brightness=  1.0 ;// Brightness control,&gt;1: brighter

/*Important for this to work!! Your Ha image must be named &quot;Ha&quot; 

Drag the bottom left arrow over to your RGB image

Hope you enjoy!!!      */









k= adev($T[0])/adev(Ha);
E1= (k*(Ha-med(Ha))+med($T[0]));//&lt;--Normalized Ha
E2= ~(~$T[0]*~(rescale(~(~Ha/~$T[0]),0,1)));// Add Ha to Red
E3= mtf((1/Brightness*.5),Ha);//&lt;-- Ha Stretch for Lightness
E4= (Ha*E3)+(Ha*~Ha);//&lt;New Lightness

// RGB to L.a.b
R1= iif(E2&gt;0.04045, ((E2+0.055)/1.055)^ 2.4,E2/ 12.92);
G1= iif($T[1]&gt;0.04045, (($T[1]+0.055)/1.055)^ 2.4,$T[1]/ 12.92);
B1= iif($T[2]&gt;0.04045, (($T[2]+0.055)/1.055)^ 2.4,$T[2]/ 12.92);
X= ((R1*0.4360747) + (G1*0.3850649) + (B1*0.1430804));
Y= ((R1*0.2225045) + (G1*0.7168786) + (B1*0.0606169));
Z= ((R1*0.0139322) + (G1*0.0971045) + (B1*0.7141733));
X1= iif(X&gt;0.008856, X^(1/3),(7.787*X)+(16/116) );
Y1= iif(Y&gt;0.008856, Y^(1/3),(7.787*Y)+(16/116) );
Z1= iif(Z&gt;0.008856, Z^(1/3),(7.787*Z)+(16/116) );
L= 116*Y1-16;  
a= (500*(X1-Y1)); 
b= (200*(Y1-Z1)); 

// L.a.b to RGB
Y2= (E4+.16)/1.16;
X2= (a/500)+Y2;
Z2= Y2-(b/200);
X3= iif(X2&gt;0.008856, X2^3,(X2-16/116)/7.787);
Y3= iif(Y2&gt;0.008856, Y2^3,(Y2-16/116)/7.787);
Z3= iif(Z2&gt;0.008856, Z2^3,(Z2-16/116)/7.787);
R2= ((X3* 3.1338561) + (Y3*-1.6168667) + (Z3*-0.4906146));
G2= ((X3*-0.9787684) + (Y3* 1.9161415) + (Z3* 0.0334540));
B2= ((X3* 0.0719453) + (Y3*-0.2289914) + (Z3* 1.4052427));
R3= iif(R2&gt;0.0031308, 1.055*(R2^(1/2.4))-0.055,12.92*R2);
G3= iif(G2&gt;0.0031308, 1.055*(G2^(1/2.4))-0.055,12.92*G2);
B3= iif(B2&gt;0.0031308, 1.055*(B2^(1/2.4))-0.055,12.92*B2);

iif($T==$T[0],R3,iif($T==$T[1],G3,B3))</parameter>
      <parameter id="expression1"></parameter>
      <parameter id="expression2"></parameter>
      <parameter id="expression3"></parameter>
      <parameter id="useSingleExpression" value="true"/>
      <parameter id="symbols">Brightness,k,E1,E2,E3,E4,
R1,G1,B1,R2,G2,B2,R3,G3,B3,
X,Y,Z,X1,Y1,Z1,X2,Y2,Z2,X3,Y3,Z3,
L,a,b,</parameter>
